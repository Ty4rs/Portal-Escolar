@model PortalEscolar.Views.Painel.IndexModel
@{
}
<style>
    /* Ajuste para o conteúdo principal não ficar escondido atrás do menu fixo */
    body {
        background-color: #f8f9fa;
    }

    .main-content {
        margin-left: 280px; /* Deve ser igual ou maior que a largura do menu */
    }

    .sidebar {
        width: 280px;
    }

    h1{
        color: #343a40;
        font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
        font-weight: bold;
        font-size: 5rem;
        position: relative;
    }
    h1::after{
        content: '';
        display: block;
