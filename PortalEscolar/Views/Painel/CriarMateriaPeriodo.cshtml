@model PortalEscolar.Views.ViewModel.MateriasViewModel
@{
}

<div class="d-flex justify-content-center align-items-center vh-100" style="margin-top:-3rem">
    <form asp-action="CadastrarMateriaPeriodo" asp-controller="painel" class="gap-1 d-flex flex-column justify-content-center container-sm w-50">
        <label asp-for="idMateria">Matéria:</label>
        <select asp-for="idMateria" class="form-control" asp-items="Model.materias"></select>
        <label asp-for="IdPeriodo">Período:</label>
        <select asp-for="IdPeriodo" class="form-control" asp-items="Model.periodos"></select>
        <label asp-for="_idCurso">Curso:</label>
        <select asp-for="_idCurso" class="form-control" asp-items="Model.cursos"></select>
        <label asp-for="Sala">Sala: </label>
        <input type="text" asp-for="Sala" class="form-control">
    
        <input type="submit" value="Cadastrar Matéria" class="btn btn-primary" style="margin-top: 0.5rem;">
    </form>
</div>

