@model PortalEscolar.Views.ViewModel.AlunoViewModel;
@{
}

<form asp-action="cadastrarAluno" asp-controller="Usuario" method="post">
    <span asp-validation-for="idUsuario" class="text-danger col-12"></span>
    <label asp-for="Nome">Nome: </label>
    <input type="text" asp-for="Nome">

    <label asp-for="Cpf">CPF: </label>
    <input type="text" asp-for="Cpf">

    <label asp-for="DataNascimento">Data de Nascimento: </label>
    <input type="date" value="2000-01-01" asp-for="DataNascimento">

    <label asp-for="Endereco">Endereço: </label>
    <input type="text" asp-for="Endereco">

    <label asp-for="Telefone">Telefone: </label>
    <input type="tel" asp-for="Telefone">

    <select asp-for="IdCurso" class="form-control" asp-items="Model.cursos"></select>

    <input type="submit" value="Cadastrar Aluno">
</form>