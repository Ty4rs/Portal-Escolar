@model PortalEscolar.Views.ViewModel.LancarNotaPaginaViewModel

@{
    ViewData["Title"] = "Lançar Notas";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Lançamento de Avaliação - @Model.NomeMateria</h3>
        </div>
        <div class="card-body">
            <form asp-action="SalvarNotas" method="post">
                <!-- IDs ocultos para manter o contexto da turma e data -->
                <input type="hidden" asp-for="IdMateriaPeriodo" />
                
                <div class="row mb-4">
                    <div class="col-md-4">
                        <label asp-for="DataAvaliacao">Data da Avaliação:</label>
                        <input asp-for="DataAvaliacao" type="date" class="form-control"/>
                    </div>
                </div>

                <table class="table align-middle">
                    <thead class="">
                        <tr>
                            <th style="width: 85%">Nome do Aluno</th>
                            <th style="width: 15%">Nota </th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Alunos.Count; i++)
                        {
                            <tr>
                                <td>
                                    @Model.Alunos[i].NomeAluno
                                    <!-- Campos ocultos para enviar os dados de volta ao Controller -->
                                    <input type="hidden" asp-for="Alunos[i].IdMatriculaMateria" />
                                    <input type="hidden" asp-for="Alunos[i].NomeAluno" />
                                </td>
                                <td>
                                    <div class="input-group">
                                        <input asp-for="Alunos[i].Nota"
                                               type="number"
                                               step="0.01"
                                               min="0"
                                               max="10"
                                               class="form-control"
                                               placeholder="0,00"
                                               required />
                                        
                                    </div>
                                    <span asp-validation-for="Alunos[i].Nota" class="text-danger small"></span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-save"></i> Salvar Notas
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>